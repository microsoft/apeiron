# =============================================================================
# Amorphware (Apeiron) environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
#
# `.env` is gitignored and MUST NEVER be committed. Do not put real secrets in
# this template. The app loads `.env` automatically via python-dotenv.
# Every variable below is read somewhere in the codebase (file noted in [brackets]).
# =============================================================================

# --- Required: core Azure OpenAI / AI Foundry ---------------------------------
# Used by sllm/llm.py and sllm/tools/cua.py
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_AI_FOUNDRY_KEY=<your_azure_ai_foundry_key>

# --- Optional: Azure auth mode (cached browser login vs API key) --------------
# Used by sllm/auth.py. Default 'interactive' uses az login / a cached
# interactive browser login (record stored under ~/.apeiron/auth/), and falls
# back to AZURE_AI_FOUNDRY_KEY only if a token can't be acquired. Set to 'key'
# to use the API key exclusively (e.g. headless/CI).
# AZURE_OPENAI_AUTH_MODE=interactive
# Set AZURE_OPENAI_AUTH_VERIFY=0 to skip the eager token check and defer login
# to the first request (lazy).
# AZURE_OPENAI_AUTH_VERIFY=1

# --- Optional: Azure OpenAI request timeout & retries -------------------------
# Used by sllm/auth.py (build_azure_openai_client). A bounded request timeout is
# always applied so a stalled endpoint fails fast instead of hanging the whole
# pipeline indefinitely (a synchronous completion call cannot be interrupted by
# an outer asyncio timeout). Tune these if a reasoning model needs longer, or
# lower the timeout to fail faster on a flaky endpoint. Defaults: 3600 seconds, 2 retries.
# AZURE_OPENAI_TIMEOUT=3600
# AZURE_OPENAI_MAX_RETRIES=2

# --- Optional: Claude via the GitHub Copilot SDK ------------------------------
# Used by sllm/copilot_client.py (model card 'claude-sonnet-4.5', provider COPILOT).
# Requires the GitHub Copilot CLI on PATH and the `copilot` (github-copilot-sdk)
# package installed. Authenticate with a Copilot token, or use the CLI's own
# logged-in session if this is unset.
# COPILOT_GITHUB_TOKEN=<your_github_copilot_token>
# BYOK alternative: route Claude to your own Anthropic key (pass
# copilot_provider='anthropic' in model_args).
# ANTHROPIC_API_KEY=<your_anthropic_api_key>

# --- Optional: Computer-Use Agent (CUA), if deployed on a separate endpoint ---
# Used by sllm/tools/cua.py and sllm/const.py (COMPUTER_USE model card)
# CUA_API_KEY=<your_cua_api_key>
# AZURE_CUA_ENDPOINT=https://<your-cua-endpoint>.cognitiveservices.azure.com/

# --- Optional: Databricks (only for Claude models) ----------------------------
# Used by sllm/llm.py
# DATABRICKS_TOKEN=<your_databricks_token>
# DATABRICKS_ENDPOINT=https://<your_databricks_endpoint>

# --- Optional: Data library API keys ------------------------------------------
# FMP_API_KEY   used by apeiron/library/modules/fmp_proxy.py   (https://site.financialmodelingprep.com/)
# FRED_API_KEY  used by apeiron/library/modules/fred_proxy.py  (https://fred.stlouisfed.org/docs/api/fred/)
# PERPLEXITY_API_KEY used by apeiron/agent/aw.py               (https://www.perplexity.ai/)
# FMP_API_KEY=<your_fmp_api_key>
# FRED_API_KEY=<your_fred_api_key>
# PERPLEXITY_API_KEY=<your_perplexity_api_key>

# --- Required: workspace directories ------------------------------------------
# Used by apeiron/system.py, apeiron/utils.py, apeiron/btool/compilers.py,
# sllm/llm.py, bin/app.py, bin/pages/home.py
# Set WS_DIR to an absolute path on your machine. The ${WS_DIR} references below
# are expanded automatically (see apeiron/utils.py). On Windows use backslashes,
# e.g. WS_DIR=C:\path\to\amorphware
WS_DIR=/path/to/amorphware
TMP_DIR=${WS_DIR}/.tmp
LOG_DIR=${WS_DIR}/.log
DATA_DIR=${WS_DIR}/data
CKPT_DIR=${WS_DIR}/ckpts
